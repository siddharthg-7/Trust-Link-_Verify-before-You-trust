# ─────────────────────────────────────────────────────────────
# TrustLink — Railway.app Environment Variables Template
# Copy this file to .env and fill in your values before deploying
# ─────────────────────────────────────────────────────────────

# ── Node.js / Express ───────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-here

# ── Python Email Service ─────────────────────────────────────
# Points to the co-located Python service (same Railway service, no external URL needed)
PYTHON_SERVICE_URL=http://127.0.0.1:5000/send-email

# Gmail SMTP credentials for the Python email service
# Use a Gmail App Password (not your account password):
#   https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Admin email that receives complaint alert notifications
ADMIN_EMAIL=your-admin@gmail.com

# ── Firebase (Auth + Firestore only — compute stays on Railway) ──
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK — paste the entire service account JSON as a single-line string
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── App URL ──────────────────────────────────────────────────
# Set to your Railway deployment URL after first deploy
# e.g. https://trust-link-production.up.railway.app
VITE_APP_URL=https://your-app.up.railway.app
APP_URL=https://your-app.up.railway.app
