{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "reportsCount": { "type": "number" },
        "votesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "trustScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Report": {
      "title": "Report",
      "description": "Scam report or analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "link": { "type": "string" },
        "riskScore": { "type": "number" },
        "category": { "type": "string", "enum": ["Scam", "Safe"] },
        "status": { "type": "string", "enum": ["Pending", "Verified", "Scam"] },
        "findings": { "type": "array", "items": { "type": "string" } },
        "aiAnalysis": { "type": "string" },
        "proofUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "comments": { "type": "array" },
        "votes": { "type": "object" }
      },
      "required": ["userId", "content", "riskScore", "category", "status"]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "Community post or poll",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "type": { "type": "string", "enum": ["post", "poll"] },
        "content": { "type": "string" },
        "pollOptions": { "type": "array" },
        "votes": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Scam reports"
    },
    "/community/{postId}": {
      "schema": "CommunityPost",
      "description": "Community posts and polls"
    },
    "/community/{postId}/comments/{commentId}": {
      "schema": { "type": "object" },
      "description": "Threaded comments"
    }
  }
}
